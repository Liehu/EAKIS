# EAKIS 测试环境配置
DATABASE_URL=sqlite:///./eakis_test.db
DATABASE_URL_ASYNC=sqlite+aiosqlite:///./eakis_test.db
DB_ECHO=false

# LLM (Mock for testing)
OPENAI_API_KEY=sk-test-key
OPENAI_MODEL=gpt-4o

# JWT Auth
JWT_SECRET_KEY=test-secret-key-for-testing-only
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# MinIO (Mock for testing)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eakis
MINIO_SECURE=false

# Cache
CACHE_TTL_DEFAULT=300

# Rate Limit
RATE_LIMIT_RPM=60

# App
APP_NAME=AttackScope AI
APP_VERSION=2.0.0
DEBUG=true
CORS_ORIGINS=["*"]

# Module Stubs
INTELLIGENCE_USE_STUBS=true
CRAWLER_USE_STUBS=true
