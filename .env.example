# EAKIS 环境变量配置模板
# 复制为 .env 后按需修改

# ---- Database ----
DATABASE_URL=postgresql+psycopg2://eakis:eakis@localhost:5432/eakis
DATABASE_URL_ASYNC=postgresql+asyncpg://eakis:eakis@localhost:5432/eakis
DB_ECHO=false

# ---- LLM ----
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- JWT Auth ----
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- MinIO Storage ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eakis
MINIO_SECURE=false

# ---- Cache ----
CACHE_TTL_DEFAULT=300

# ---- Rate Limit ----
RATE_LIMIT_RPM=60

# ---- App ----
APP_NAME=AttackScope AI
APP_VERSION=2.0.0
DEBUG=true
CORS_ORIGINS=["*"]

# ---- Module Stubs ----
INTELLIGENCE_USE_STUBS=true
CRAWLER_USE_STUBS=true
